# ============================================================
# Bug-1 修复：col_valid 对 gemmi.Column 的判断不可靠
# ============================================================
# 原代码 bool(col) 在某些 gemmi 版本中会因 Column 对象
# 重载 __bool__ 为"有无数据行"而非"tag是否存在"，
# 导致空列被误判为有效。改用 len() 双重验证。

def col_valid(col):
    """
    判断 find_loop 返回的 Column 是否含有效数据。
    双重验证：① tag存在性  ② 至少有1行数据
    """
    try:
        if col is None:
            return False
        # gemmi LoopColumn: bool 测试 tag 是否找到
        if not bool(col):
            return False
        # 再验证确实有数据行
        return len(col) > 0
    except Exception:
        return False

def iter_col_str(col):
    """
    安全迭代 gemmi Column，逐个返回字符串值。
    注意：item 本身是字符串，不能用 item[0]（那是字符取第一个字符）
    """
    for item in col:
        yield str(item)

def safe_float(val, default=np.nan):
    """处理括号不确定度、问号、None等，安全转 float。"""
    if val is None:
        return default
    s = str(val).strip()
    # Bug-2 修复：原代码未处理 '?' 和 '.' 占位符
    if s in ('?', '.', '', 'nan', 'None'):
        return default
    try:
        return float(re.sub(r'\(\d+\)$', '', s))
    except (ValueError, TypeError):
        return default

def find_val(block, tag, default=None):
    """block.find_value 的安全封装。"""
    try:
        v = block.find_value(tag)
        # Bug-3 修复：gemmi 在 tag 不存在时返回 None 或空字符串
        # 但有时返回 '?' 或 '.' 作为 CIF 缺失值占位符
        if v is None:
            return default
        s = str(v).strip()
        if s in ('?', '.', ''):
            return default
        return s
    except Exception:
        return default

