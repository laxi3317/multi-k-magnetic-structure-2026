# 元素符号提取
# ============================================================

def elem_from_type_symbol(s):
    """
    _atom_site_type_symbol 的值，如 'Mn', 'Fe2+', 'O2-'
    提取纯元素符号。
    """
    s = re.sub(r'[^A-Za-z]', '', str(s).strip())
    if not s:
        return ''
    return s[0].upper() + s[1:].lower()

def elem_from_label(s):
    """
    _atom_site_label 的值，如 'Mn1_1', 'Co1_2'
    开头的字母部分就是元素符号。
    """
    m = re.match(r'^([A-Za-z]{1,2})', str(s).strip())
    if not m:
        return ''
    raw = m.group(1)
    return raw[0].upper() + raw[1:].lower()

# Bug-4 修复：is_valid_elem 未过滤常见非元素字符串
INVALID_ELEM_STRS = {
    'X', 'Xx', 'Du', 'D',   # 虚原子/氘
    'An', 'Ln',              # 系列占位符
}

def is_valid_elem(sym):
    """验证元素符号：1-2字母，不是占位符，不是虚原子。"""
    if not sym or not (1 <= len(sym) <= 2):
        return False
    if sym in INVALID_ELEM_STRS:
        return False
    # 必须以大写字母开头
    if not sym[0].isupper():
        return False
    return True

