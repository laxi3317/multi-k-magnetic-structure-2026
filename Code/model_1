                       np.int64,   np.int32,
                       np.int16,   np.int8]
]

BLACKLIST = [
   'k_vector','irrep','mag_sym','moment','bns',
   'magnetic_sg','time_reversal','symmform','num_k','k_mag'
]
for kw in BLACKLIST:
   feat_cols = [f for f in feat_cols if kw not in f.lower()]

ZERO_FILL = [
   'has_', 'tb_', 'tt_gt', 'tt_lt', 'proxy_',
   'ab_eq', 'abc_eq', 'cs_low', 'cs_mid', 'cs_high',
   'cs_hex', 'cs_cub', 'cs_1', 'cs_2', 'cs_3',
   'cs_4', 'cs_5', 'cs_6', 'cs_7', 'has_tt',
   'has_mag', 'has_re', 'has_both', 'has_part', 'wcv', 'ws',
   'sg_in_', 'has_3d', 'has_4d5d', 'has_4f', 'has_5f',
   'has_strong_soc', 'has_heavy_mag', 'is_right_angle',
