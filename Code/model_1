ax = axes[1]
for name, (proba, th) in MODELS.items():
   fpr, tpr, _ = roc_curve(y_test, proba)
   auc_roc     = roc_auc_score(y_test, proba)
   ax.plot(fpr, tpr, label=f'{name} (AUC={auc_roc:.3f})',
